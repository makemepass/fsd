###Perform Count, Limit, Sort, and Skip operations on the given collections using MongoDB.


const { MongoClient } = require('mongodb');
const url = 'mongodb://127.0.0.1:27017';
const client = new MongoClient(url);
async function main() {
    try {
        await client.connect();
        const db = client.db('labDB');
        const collection = db.collection('products');
        await collection.deleteMany({});
        await collection.insertMany([
            { name: 'Mouse', price: 20 },
            { name: 'Keyboard', price: 80 },
            { name: 'Laptop', price: 900 }
        ]);
        console.log('Successfully connected and setup data.');

        console.log('\n--- 1. COUNT ---');
        const total = await collection.countDocuments({});
        console.log('Total items in collection:', total);

        console.log('\n--- 2. SORT ---');
        const sorted = await collection.find({}).sort({ price: -1 }).toArray();
        console.log('Highest priced item:', sorted[0].name, '-', sorted[0].price);

        console.log('\n--- 3. LIMIT ---');
        const limited = await collection.find({}).limit(2).toArray();
        console.log('First 2 items:', limited[0].name, 'and', limited[1].name);

        console.log('\n--- 4. SKIP ---');
        const skipped = await collection.find({}).skip(2).toArray();
        console.log('Item after skipping 2:', skipped[0].name);

    } catch (err) {
        console.error('Error:', err);
    } finally {
        await client.close();
        console.log('\nDatabase connection closed.');
    }
}
main();
