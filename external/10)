##To demonstrate data binding using events (event binding) in Angular.


###file name app.ts###
import { Component } from '@angular/core';
@Component({
  selector: 'app-root',
  templateUrl: './app.component.html',
  styleUrls: ['./app.component.css']
})
export class AppComponent {
  counter: number = 0;
  typedMessage: string = '';
  incrementCounter(): void {
    this.counter++;
  }
  onInputChange(event: any): void {
    this.typedMessage = event.target.value;
  }
}



###file name app.html###
<h3>Click Event Counter</h3>
<p>Current Count: {{ counter }}</p>
<button (click)="incrementCounter()">Increment</button>
<h3>Keystroke Input Event</h3>
<input type="text" (input)="onInputChange($event)" placeholder="Type here...">
<p>Live Output: {{ typedMessage }}</p>
