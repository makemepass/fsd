const { MongoClient } = require('mongodb');

const url = 'mongodb://localhost:27017'; 
const dbName = 'inventoryDB';
const collectionName = 'products';

async function main() {
    const client = new MongoClient(url);

    try {
        await client.connect();
        console.log('Successfully connected to MongoDB server');
        
        const db = client.db(dbName);
        const collection = db.collection(collectionName);

        await collection.deleteMany({}); // Clears collection for a predictable output
        await collection.insertMany([
            { name: 'Laptop', price: 999.99, category: 'Electronics', stock: 10 },
            { name: 'Wireless Mouse', price: 29.99, category: 'Electronics', stock: 150 },
            { name: 'Mechanical Keyboard', price: 89.99, category: 'Electronics', stock: 45 },
            { name: 'Monitor', price: 249.99, category: 'Electronics', stock: 20 },
            { name: 'HDMI Cable', price: 14.99, category: 'Electronics', stock: 300 }
        ]);
        console.log('Mock data seeded successfully.');

        console.log('\n--- Executing COUNT ---');
        const electronicsCount = await collection.countDocuments({ category: 'Electronics' });
        console.log(`Total items matching 'Electronics': ${electronicsCount}`);

        console.log('\n--- Executing SORT (Price: High to Low) ---');
        const sortedProducts = await collection.find({})
            .sort({ price: -1 }) 
            .toArray();
        
        sortedProducts.forEach(p => console.log(` - ${p.name}: $${p.price}`));

        console.log('\n--- Executing LIMIT (Get exactly 2 items) ---');
        const limitedProducts = await collection.find({})
            .limit(2)
            .toArray();

        limitedProducts.forEach(p => console.log(` - ${p.name}`));

        console.log('\n--- Executing SKIP (Bypass first 3 items) ---');
        const skippedProducts = await collection.find({})
            .skip(3)
            .toArray();

        skippedProducts.forEach(p => console.log(` - ${p.name}`));

    } catch (error) {
        console.error('An error occurred:', error);
    } finally {      
        await client.close();
        console.log('\nMongoDB connection closed.');
    }
}

// Run script
main().catch(console.error);
