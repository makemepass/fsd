###filename app.ts###
import { Component, signal } from '@angular/core';
import { RouterOutlet } from '@angular/router';
import { Header } from './header';
import { Footer } from './footer';

@Component({
  selector: 'app-root',
  standalone: true,
  // We include Header and Footer here so this component recognizes their tags
  imports: [RouterOutlet, Header, Footer],
  template: `
    <app-header></app-header>

    <main style="padding: 20px;">
      <h2>Main Content Area</h2>
      <p>Welcome to the main body of the application. The title is: {{ title() }}</p>
    </main>

    <app-footer></app-footer>
  `
})
export class App {
  protected readonly title = signal('Components Demo');
}
