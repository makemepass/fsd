import { Component } from '@angular/core';

@Component({
  selector: 'app-root',
  templateUrl: './app.component.html',
  styleUrls: ['./app.component.css']
})
export class AppComponent {
  // Application Data States
  counter: number = 0;
  typedMessage: string = '';

  // Method triggered by the click event
  incrementCounter(): void {
    this.counter++;
  }

  // Method triggered by the input event, capturing user keystrokes
  onInputChange(event: any): void {
    this.typedMessage = event.target.value;
  }
}



###file name app.html###
<div style="padding: 20px; font-family: Arial, sans-serif;">
  <h2>Angular Event Binding Demonstration</h2>
  <hr />

  <div style="margin-bottom: 20px;">
    <h3>Example 1: Click Event Counter</h3>
    <p>Current Count: <strong>{{ counter }}</strong></p>
    
    <button (click)="incrementCounter()">Increment Count</button>
  </div>

  <hr />

  <div>
    <h3>Example 2: Keystroke Input Event</h3>
    <label for="user-input">Type something: </label>
    
    <input 
      id="user-input"
      type="text" 
      (input)="onInputChange($event)" 
      placeholder="Start typing..." 
    />
    
    <p>Live Output: <span style="color: blue;">{{ typedMessage }}</span></p>
  </div>
</div>
